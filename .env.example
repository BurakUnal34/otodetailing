# ——— Veritabanı ———
# Yerel geliştirme (Docker PostgreSQL — `npm run db:up` ile ayağa kaldırılır):
DATABASE_URL="postgresql://otodetailing:otodetailing@localhost:5432/otodetailing?schema=public"
# Canlı (Vercel / Neon / Supabase):
# DATABASE_URL="postgresql://USER:PASS@HOST:5432/DB?schema=public&sslmode=require"

# ——— Site & oturum ———
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
# Canlıda mutlaka değiştirin: `openssl rand -base64 32`
NEXTAUTH_SECRET="gelistirme-icin-uzun-rastgele-bir-dize-min-32-karakter"

# ——— Ödeme sağlayıcısı ———
# stripe (varsayılan) veya iyzico
PAYMENT_PROVIDER="stripe"
NEXT_PUBLIC_PAYMENT_PROVIDER="stripe"

# ——— Stripe ———
# Test: sk_test_... / pk_test_... — Canlı: sk_live_... / pk_live_...
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Vercel'e webhook eklendikten sonra Stripe'tan alınan değer
STRIPE_WEBHOOK_SECRET="whsec_..."

# ——— iyzico (PAYMENT_PROVIDER=iyzico ise) ———
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
# sandbox: https://sandbox-api.iyzipay.com  ·  prod: https://api.iyzipay.com
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"

# ——— İzleme (Sentry) — opsiyonel ———
# DSN tanımlandığında istemci + sunucu hata raporlama otomatik aktif
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
# Sadece source map yüklemesi için (build adımı):
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"

# ——— Vercel Blob (görsel yükleme) ———
# Üretim için ŞART; yoksa görseller her deploy'da silinir
BLOB_READ_WRITE_TOKEN=""

# ——— E-posta (Resend) — opsiyonel ———
# Boş bırakılırsa sipariş e-postaları gönderilmez (loglanır)
RESEND_API_KEY=""
RESEND_FROM="Oto Detailing <siparis@alanadiniz.com>"
ORDER_NOTIFICATION_EMAIL=""

# ——— İlk admin (ilk seed çalışmasında kullanılır) ———
# Canlıda mutlaka değiştirin; admin@otodetailing.local / admin123 KESİNLİKLE bırakılmamalı
ADMIN_EMAIL="admin@otodetailing.local"
ADMIN_PASSWORD="admin123"

# ——— Harita & sosyal ———
NEXT_PUBLIC_MAP_EMBED_URL="https://www.openstreetmap.org/export/embed.html?bbox=28.8585%2C41.0404%2C28.8616%2C41.0417&layer=mapnik&marker=41.0410625%2C28.8600414"
NEXT_PUBLIC_SOCIAL_INSTAGRAM=""
NEXT_PUBLIC_SOCIAL_FACEBOOK=""
NEXT_PUBLIC_SOCIAL_X=""
NEXT_PUBLIC_SOCIAL_YOUTUBE=""
NEXT_PUBLIC_WHATSAPP_PHONE=""

# ——— İşletme bilgileri (footer / iletişim sayfası) ———
NEXT_PUBLIC_BUSINESS_NAME="Oto Detailing"
NEXT_PUBLIC_BUSINESS_LEGAL_NAME=""
NEXT_PUBLIC_BUSINESS_TAX_OFFICE=""
NEXT_PUBLIC_BUSINESS_TAX_NUMBER=""
NEXT_PUBLIC_BUSINESS_MERSIS=""
NEXT_PUBLIC_BUSINESS_PHONE=""
NEXT_PUBLIC_BUSINESS_EMAIL=""

# ——— Hero override (opsiyonel) ———
# Tanımlanırsa varsayılan hero slaytları yerine kullanılır.
# JSON dizisi olmalıdır; örnek:
# [{"src":"/img/1.png","alt":"...","content":{"label":"...","title":"...","description":"...","primary":{"href":"/urunler","label":"İncele"}}}]
NEXT_PUBLIC_HERO_SLIDES=""
